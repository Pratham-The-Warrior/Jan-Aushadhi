# ===========================================
# JAN AUSHADHI BACKEND ENVIRONMENT CONFIG
# Copy this file to .env and fill in the values.
# ===========================================

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL + PostGIS
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/janaushadhi"

# Meilisearch
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="masterKey"

# Redis
REDIS_URL="redis://localhost:6379"

# Firebase Admin (paste the full service account JSON as a single line)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Google Maps Geocoding (for store geocoding ETL script)
GOOGLE_MAPS_API_KEY=

# Twilio WhatsApp (Module 7 — leave blank for mock mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
